<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_primary">

    <com.amap.api.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/map_scrim" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/space_lg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DeviceTracker.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentInsetStartWithNavigation="0dp"
            android:minHeight="56dp"
            app:navigationIcon="@drawable/ic_fleet_close"
            app:subtitle="@string/live_location_network"
            app:title="@string/track_map_title" />

        <LinearLayout
            android:id="@+id/trackSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_panel_survey_primary"
            android:gravity="center_vertical"
            android:minHeight="@dimen/hud_primary_card_min_height"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/trackSummaryTitleText"
                    style="@style/TextAppearance.DeviceTracker.Overline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/track_summary_label" />

                <TextView
                    android:id="@+id/trackSummaryBodyText"
                    style="@style/TextAppearance.DeviceTracker.MetricCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/trackSummaryMetaText"
                style="@style/TextAppearance.DeviceTracker.StatusCompact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:background="@drawable/bg_panel_survey_secondary"
                android:gravity="center"
                android:minWidth="96dp"
                android:paddingStart="@dimen/space_md"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAlignment="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trackStatePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_state_panel_survey"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:visibility="gone">

            <TextView
                android:id="@+id/trackStateTitleText"
                style="@style/TextAppearance.DeviceTracker.Overline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/track_empty_title" />

            <TextView
                android:id="@+id/trackStateBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:breakStrategy="balanced"
                android:hyphenationFrequency="normal"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textAlignment="viewStart"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trackStateActionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:layout_gravity="start"
                android:minWidth="0dp"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:textAllCaps="false"
                android:textColor="@color/surface_primary"
                android:visibility="gone"
                app:backgroundTint="@color/accent_primary" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
