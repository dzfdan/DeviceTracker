<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#3386B8A8">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radius_button" />
                    <solid android:color="@color/surface_overlay_soft" />
                    <stroke android:width="1dp" android:color="@color/stroke_subtle" />
                    <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radius_button" />
                    <solid android:color="@color/surface_panel" />
                    <stroke android:width="1dp" android:color="@color/accent_primary" />
                    <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
                </shape>
            </item>
            <item android:state_activated="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radius_button" />
                    <solid android:color="@color/surface_panel" />
                    <stroke android:width="1dp" android:color="@color/accent_primary" />
                    <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
                </shape>
            </item>
            <item android:state_selected="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radius_button" />
                    <solid android:color="@color/surface_panel" />
                    <stroke android:width="1dp" android:color="@color/accent_primary" />
                    <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/radius_button" />
                    <solid android:color="@color/surface_overlay" />
                    <stroke android:width="1dp" android:color="@color/stroke_subtle" />
                    <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
                </shape>
            </item>
        </selector>
    </item>
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/radius_button" />
            <solid android:color="@android:color/white" />
            <size android:width="@dimen/fab_shell_size" android:height="@dimen/fab_shell_size" />
        </shape>
    </item>
</ripple>
